{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ady-olist-ecomm"
		},
		"ADLSforCSV_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLSforCSV'"
		},
		"ADLSforSQLLinkedService_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLSforSQLLinkedService'"
		},
		"filessSQLDB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'filessSQLDB'"
		},
		"ADLSforCSV_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adyolistdatastorage.dfs.core.windows.net/"
		},
		"ADLSforSQLLinkedService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adyolistdatastorage.dfs.core.windows.net/"
		},
		"JsonForGithubForLoop_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/ady007/"
		},
		"filessSQLDB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "4nnyzb.h.filess.io"
		},
		"filessSQLDB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "olist_project_woodenarm"
		},
		"filessSQLDB_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "olist_project_woodenarm"
		},
		"httpGithubLinkedService_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/ady007/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ady-olist-ecomm_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLSforCSV_accountKey": {
						"value": "[parameters('ADLSforCSV_accountKey')]"
					},
					"ADLSforSQLLinkedService_accountKey": {
						"value": "[parameters('ADLSforSQLLinkedService_accountKey')]"
					},
					"filessSQLDB_password": {
						"value": "[parameters('filessSQLDB_password')]"
					},
					"ADLSforCSV_properties_typeProperties_url": {
						"value": "[parameters('ADLSforCSV_properties_typeProperties_url')]"
					},
					"ADLSforSQLLinkedService_properties_typeProperties_url": {
						"value": "[parameters('ADLSforSQLLinkedService_properties_typeProperties_url')]"
					},
					"JsonForGithubForLoop_properties_typeProperties_url": {
						"value": "[parameters('JsonForGithubForLoop_properties_typeProperties_url')]"
					},
					"filessSQLDB_properties_typeProperties_server": {
						"value": "[parameters('filessSQLDB_properties_typeProperties_server')]"
					},
					"filessSQLDB_properties_typeProperties_database": {
						"value": "[parameters('filessSQLDB_properties_typeProperties_database')]"
					},
					"filessSQLDB_properties_typeProperties_username": {
						"value": "[parameters('filessSQLDB_properties_typeProperties_username')]"
					},
					"httpGithubLinkedService_properties_typeProperties_url": {
						"value": "[parameters('httpGithubLinkedService_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}